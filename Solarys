--// NOCLIP

local function enableNoclip()
	if not character then return end

	for _, object in ipairs(character:GetDescendants()) do
		if object:IsA("BasePart") then
			if originalCollision[object] == nil then
				originalCollision[object] = object.CanCollide
			end

			object.CanCollide = false
		end
	end
end

local function disableNoclip()
	for part, oldValue in pairs(originalCollision) do
		if part and part.Parent then
			part.CanCollide = oldValue
		end
	end

	table.clear(originalCollision)
end

local function updateNoclip()
	if state.Noclip then
		enableNoclip()
	end
end

--// FLY

local function destroyFly()
	if linearVelocity then
		linearVelocity:Destroy()
		linearVelocity = nil
	end

	if alignOrientation then
		alignOrientation:Destroy()
		alignOrientation = nil
	end

	if flyAttachment then
		flyAttachment:Destroy()
		flyAttachment = nil
	end
end

local function startFly()
	if not humanoid or not rootPart then return end

	currentVelocity = Vector3.zero

	humanoid.PlatformStand = true
	humanoid.AutoRotate = false
	humanoid:ChangeState(Enum.HumanoidStateType.Physics)

	flyAttachment = Instance.new("Attachment")
	flyAttachment.Name = "NewHearthFlyAttachment"
	flyAttachment.Parent = rootPart

	linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.Name = "NewHearthLinearVelocity"
	linearVelocity.Attachment0 = flyAttachment
	linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
	linearVelocity.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
	linearVelocity.VectorVelocity = Vector3.zero
	linearVelocity.MaxForce = math.huge
	linearVelocity.Parent = rootPart

	alignOrientation = Instance.new("AlignOrientation")
	alignOrientation.Name = "NewHearthAlignOrientation"
	alignOrientation.Attachment0 = flyAttachment
	alignOrientation.Mode = Enum.OrientationAlignmentMode.OneAttachment
	alignOrientation.RigidityEnabled = true
	alignOrientation.MaxTorque = math.huge
	alignOrientation.Responsiveness = 22
	alignOrientation.Parent = rootPart
end

local function stopFly()
	currentVelocity = Vector3.zero

	if humanoid then
		humanoid.PlatformStand = false
		humanoid.AutoRotate = true
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

	destroyFly()
end

--// AIM ASSIST PROPRE

local function hasLineOfSight(targetCharacter, targetPart)
	if not state.WallCheck then
		return true
	end

	if not player.Character then
		return false
	end

	local origin = camera.CFrame.Position
	local direction = targetPart.Position - origin

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {
		player.Character,
		camera
	}

	local result = workspace:Raycast(origin, direction, params)

	if not result then
		return true
	end

	return targetCharacter:IsAncestorOf(result.Instance)
end

local function getClosestAimTarget()
	if not camera then return nil end

	local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

	local closestPart = nil
	local closestName = "Aucune"
	local closestScreenDistance = math.huge

	for _, otherPlayer in ipairs(playerList) do
		if otherPlayer ~= player and otherPlayer.Character and isAlive(otherPlayer.Character) and isEnemy(otherPlayer) then
			local part = getSafeTargetPart(otherPlayer.Character)

			if part then
				local distance = (camera.CFrame.Position - part.Position).Magnitude

				if distance <= state.AimMaxDistance and hasLineOfSight(otherPlayer.Character, part) then
					local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)

					if onScreen then
						local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
						local screenDistance = (screenPoint - center).Magnitude

						if screenDistance <= state.AimFOV and screenDistance < closestScreenDistance then
							closestScreenDistance = screenDistance
							closestPart = part
							closestName = otherPlayer.Name
						end
					end
				end
			end
		end
	end

	currentTargetName = closestName
	return closestPart
end

local function shouldAimAssist()
	if not state.AimAssist then
		return false
	end

	if state.AimHold then
		return holdingAim
	end

	return true
end

--// TP NEAREST ENEMY

local function getNearestEnemy()
	if not rootPart then return nil end

	local nearestPlayer = nil
	local nearestDistance = math.huge

	for _, otherPlayer in ipairs(playerList) do
		if otherPlayer ~= player and otherPlayer.Character and isAlive(otherPlayer.Character) and isEnemy(otherPlayer) then
			local targetRoot = getSafeRoot(otherPlayer.Character)

			if targetRoot then
				local distance = (rootPart.Position - targetRoot.Position).Magnitude

				if distance < nearestDistance then
					nearestDistance = distance
					nearestPlayer = otherPlayer
				end
			end
		end
	end

	return nearestPlayer
end

local function teleportNearEnemy()
	local targetPlayer = getNearestEnemy()
	if not targetPlayer or not targetPlayer.Character or not rootPart then return end

	local targetRoot = getSafeRoot(targetPlayer.Character)
	if not targetRoot then return end

	local pos = targetRoot.Position - targetRoot.CFrame.LookVector * state.TPDistance + Vector3.new(0, 2, 0)
	rootPart.CFrame = CFrame.lookAt(pos, targetRoot.Position)
end

--// ESP ADMIN COMPLET : BOX 2D + VIE + INFOS + HIGHLIGHT

local ESP_THEME = {
	BoxLine = Color3.fromRGB(190, 255, 200), -- vert clair pâle
	BoxSoft = Color3.fromRGB(225, 255, 230),

	HealthBack = Color3.fromRGB(8, 12, 18),
	HealthFull = Color3.fromRGB(60, 210, 255), -- cyan, différent de la box
	HealthMid = Color3.fromRGB(255, 190, 70),
	HealthLow = Color3.fromRGB(255, 70, 70),

	Text = Color3.fromRGB(245, 245, 245)
}

local ESP_LINE_THICKNESS = 1
local ESP_HEALTH_WIDTH = 3
local ESP_HEALTH_GAP = 4
local ESP_BOX_PADDING = 4
local ESP_UPDATE_RATE = 0.12 -- optimisé : 8 fois/sec au lieu de 30+ fois/sec
local ESP_TEXT_UPDATE_RATE = 0.35 -- le texte est plus lourd, on le met à jour moins souvent

local function getESPHealthColor(percent)
	if percent > 0.5 then
		return ESP_THEME.HealthFull
	elseif percent > 0.25 then
		return ESP_THEME.HealthMid
	else
		return ESP_THEME.HealthLow
	end
end

local function makeESPLine(parent, name)
	local line = Instance.new("Frame")
	line.Name = name
	line.BackgroundColor3 = ESP_THEME.BoxLine
	line.BackgroundTransparency = 0.05
	line.BorderSizePixel = 0
	line.ZIndex = 60
	line.Parent = parent
	return line
end

local function getESPTeamName(targetPlayer)
	if targetPlayer.Team then
		return targetPlayer.Team.Name
	end

	return "Aucune"
end

local function getESPGrade(targetPlayer, targetCharacter)
	local grade =
		targetPlayer:GetAttribute("Grade")
		or targetPlayer:GetAttribute("Rank")
		or targetPlayer:GetAttribute("Rang")
		or targetPlayer:GetAttribute("Role")

	if not grade and targetCharacter then
		grade =
			targetCharacter:GetAttribute("Grade")
			or targetCharacter:GetAttribute("Rank")
			or targetCharacter:GetAttribute("Rang")
			or targetCharacter:GetAttribute("Role")
	end

	local leaderstats = targetPlayer:FindFirstChild("leaderstats")

	if not grade and leaderstats then
		local stat =
			leaderstats:FindFirstChild("Grade")
			or leaderstats:FindFirstChild("Rank")
			or leaderstats:FindFirstChild("Rang")
			or leaderstats:FindFirstChild("Role")

		if stat and stat:IsA("ValueBase") then
			grade = stat.Value
		end
	end

	return grade and tostring(grade) or "Aucun"
end

local function getESPEquippedTool(targetCharacter)
	if not targetCharacter then
		return "Aucun"
	end

	local tool = targetCharacter:FindFirstChildOfClass("Tool")
	return tool and tool.Name or "Aucun"
end

local function getESPDistance(targetCharacter)
	local myRoot = character and getSafeRoot(character)
	local targetRoot = targetCharacter and getSafeRoot(targetCharacter)

	if myRoot and targetRoot then
		return math.floor((myRoot.Position - targetRoot.Position).Magnitude)
	end

	return 0
end

local function getESPInfoText(targetPlayer, targetCharacter, targetHumanoid)
	local hp = math.floor(targetHumanoid.Health)
	local maxHp = math.floor(targetHumanoid.MaxHealth)

	return targetPlayer.DisplayName .. " @" .. targetPlayer.Name ..
		"\nTeam : " .. getESPTeamName(targetPlayer) ..
		"\nGrade : " .. getESPGrade(targetPlayer, targetCharacter) ..
		"\nVie : " .. hp .. " / " .. maxHp ..
		"\nDistance : " .. getESPDistance(targetCharacter) .. " studs" ..
		"\nOutil : " .. getESPEquippedTool(targetCharacter)
end

local function createESPForPlayer(targetPlayer)
	if targetPlayer == player then return end
	if espObjects[targetPlayer] then return end
	if not targetPlayer.Character then return end

	local model = targetPlayer.Character
	local hum = model:FindFirstChildOfClass("Humanoid")
	local root = getSafeRoot(model)

	if not hum or hum.Health <= 0 or not root then
		return
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = "NewHearthAdminESP_Highlight"
	highlight.Adornee = model
	highlight.FillTransparency = 1
	highlight.OutlineTransparency = 0.15
	highlight.OutlineColor = ESP_THEME.BoxSoft
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Enabled = state.ESPHighlight
	highlight.Parent = model

	local screenBox = Instance.new("Frame")
	screenBox.Name = "NewHearthAdminESP_Box_" .. targetPlayer.Name
	screenBox.BackgroundTransparency = 1
	screenBox.Visible = false
	screenBox.ZIndex = 55
	screenBox.Parent = screenGui

	local top = makeESPLine(screenBox, "Top")
	local bottom = makeESPLine(screenBox, "Bottom")
	local left = makeESPLine(screenBox, "Left")
	local right = makeESPLine(screenBox, "Right")

	local healthBack = Instance.new("Frame")
	healthBack.Name = "HealthBack"
	healthBack.BackgroundColor3 = ESP_THEME.HealthBack
	healthBack.BackgroundTransparency = 0.15
	healthBack.BorderSizePixel = 0
	healthBack.ZIndex = 61
	healthBack.Parent = screenBox

	local healthFill = Instance.new("Frame")
	healthFill.Name = "HealthFill"
	healthFill.AnchorPoint = Vector2.new(0, 1)
	healthFill.Position = UDim2.new(0, 0, 1, 0)
	healthFill.Size = UDim2.new(1, 0, 1, 0)
	healthFill.BackgroundColor3 = ESP_THEME.HealthFull
	healthFill.BorderSizePixel = 0
	healthFill.ZIndex = 62
	healthFill.Parent = healthBack

	local infoLabel = Instance.new("TextLabel")
	infoLabel.Name = "InfoLabel"
	infoLabel.BackgroundTransparency = 1
	infoLabel.TextColor3 = ESP_THEME.Text
	infoLabel.TextSize = 10
	infoLabel.Font = Enum.Font.GothamMedium
	infoLabel.TextStrokeTransparency = 0.35
	infoLabel.TextXAlignment = Enum.TextXAlignment.Center
	infoLabel.TextYAlignment = Enum.TextYAlignment.Bottom
	infoLabel.ZIndex = 62
	infoLabel.Parent = screenBox

	espObjects[targetPlayer] = {
		Model = model,
		Humanoid = hum,
		Root = root,
		LastInfoUpdate = 0,
		Highlight = highlight,
		ScreenBox = screenBox,
		Top = top,
		Bottom = bottom,
		Left = left,
		Right = right,
		HealthBack = healthBack,
		HealthFill = healthFill,
		InfoLabel = infoLabel,
	}
end

local function removeESPForPlayer(targetPlayer)
	local data = espObjects[targetPlayer]
	if not data then return end

	if data.Highlight then
		data.Highlight:Destroy()
	end

	if data.ScreenBox then
		data.ScreenBox:Destroy()
	end

	espObjects[targetPlayer] = nil
end

local function clearESP()
	for targetPlayer in pairs(espObjects) do
		removeESPForPlayer(targetPlayer)
	end
end

local espTimer = 0

local function updateESPObject(targetPlayer, data, now)
	local model = targetPlayer.Character

	if not model or not model.Parent then
		removeESPForPlayer(targetPlayer)
		return
	end

	local hum = data.Humanoid
	local root = data.Root

	if not hum or hum.Parent ~= model then
		hum = model:FindFirstChildOfClass("Humanoid")
		data.Humanoid = hum
	end

	if not root or root.Parent ~= model then
		root = getSafeRoot(model)
		data.Root = root
	end

	if not hum or hum.Health <= 0 or not root then
		removeESPForPlayer(targetPlayer)
		return
	end

	if root and camera then
		local distance = (camera.CFrame.Position - root.Position).Magnitude

		if distance > state.ESPMaxDistance then
			data.ScreenBox.Visible = false
			if data.Highlight then
				data.Highlight.Enabled = false
			end
			return
		end
	end

	local success, cframe, size = pcall(function()
		return model:GetBoundingBox()
	end)

	if not success or not camera then
		data.ScreenBox.Visible = false
		return
	end

	local half = size / 2

	local corners = {
		Vector3.new(-half.X, -half.Y, -half.Z),
		Vector3.new(-half.X, -half.Y, half.Z),
		Vector3.new(-half.X, half.Y, -half.Z),
		Vector3.new(-half.X, half.Y, half.Z),
		Vector3.new(half.X, -half.Y, -half.Z),
		Vector3.new(half.X, -half.Y, half.Z),
		Vector3.new(half.X, half.Y, -half.Z),
		Vector3.new(half.X, half.Y, half.Z)
	}

	local minX, minY = math.huge, math.huge
	local maxX, maxY = -math.huge, -math.huge
	local visible = false

	for _, cornerPoint in ipairs(corners) do
		local worldPoint = cframe:PointToWorldSpace(cornerPoint)
		local screenPoint = camera:WorldToViewportPoint(worldPoint)

		if screenPoint.Z > 0 then
			visible = true
			minX = math.min(minX, screenPoint.X)
			minY = math.min(minY, screenPoint.Y)
			maxX = math.max(maxX, screenPoint.X)
			maxY = math.max(maxY, screenPoint.Y)
		end
	end

	if not visible then
		data.ScreenBox.Visible = false
		return
	end

	local x = minX - ESP_BOX_PADDING
	local y = minY - ESP_BOX_PADDING
	local width = (maxX - minX) + (ESP_BOX_PADDING * 2)
	local height = (maxY - minY) + (ESP_BOX_PADDING * 2)

	if width < 18 or height < 32 then
		data.ScreenBox.Visible = false
		return
	end

	data.ScreenBox.Visible = true
	data.ScreenBox.Position = UDim2.fromOffset(x, y)
	data.ScreenBox.Size = UDim2.fromOffset(width, height)

	data.Top.Visible = state.ESPBox
	data.Bottom.Visible = state.ESPBox
	data.Left.Visible = state.ESPBox
	data.Right.Visible = state.ESPBox

	data.Top.Position = UDim2.fromOffset(0, 0)
	data.Top.Size = UDim2.new(1, 0, 0, ESP_LINE_THICKNESS)

	data.Bottom.Position = UDim2.new(0, 0, 1, -ESP_LINE_THICKNESS)
	data.Bottom.Size = UDim2.new(1, 0, 0, ESP_LINE_THICKNESS)

	data.Left.Position = UDim2.fromOffset(0, 0)
	data.Left.Size = UDim2.new(0, ESP_LINE_THICKNESS, 1, 0)

	data.Right.Position = UDim2.new(1, -ESP_LINE_THICKNESS, 0, 0)
	data.Right.Size = UDim2.new(0, ESP_LINE_THICKNESS, 1, 0)

	data.HealthBack.Visible = state.ESPHealth
	data.HealthBack.Position = UDim2.new(1, ESP_HEALTH_GAP, 0, 0)
	data.HealthBack.Size = UDim2.new(0, ESP_HEALTH_WIDTH, 1, 0)

	local percent = 0

	if hum.MaxHealth > 0 then
		percent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
	end

	data.HealthFill.Size = UDim2.new(1, 0, percent, 0)
	data.HealthFill.BackgroundColor3 = getESPHealthColor(percent)

	local showText = state.ESPInfo and state.ESPNames
	data.InfoLabel.Visible = showText
	data.InfoLabel.Position = UDim2.new(0, -85, 0, -88)
	data.InfoLabel.Size = UDim2.new(1, 170, 0, 84)

	if showText and (now - (data.LastInfoUpdate or 0)) >= ESP_TEXT_UPDATE_RATE then
		data.InfoLabel.Text = getESPInfoText(targetPlayer, model, hum)
		data.LastInfoUpdate = now
	end

	if data.Highlight and data.Highlight.Enabled ~= state.ESPHighlight then
		data.Highlight.Enabled = state.ESPHighlight
	end
end

local function updateESP(dt)
	if not state.ESP then
		return
	end

	espTimer += dt

	if espTimer < ESP_UPDATE_RATE then
		return
	end

	espTimer = 0
	local now = os.clock()
	local camPos = camera and camera.CFrame.Position

	-- Création uniquement des ESP utiles, pas pour les joueurs trop loin
	for _, targetPlayer in ipairs(playerList) do
		if targetPlayer ~= player and targetPlayer.Character and isAlive(targetPlayer.Character) then
			local root = getSafeRoot(targetPlayer.Character)

			if root and camPos then
				local distance = (camPos - root.Position).Magnitude

				if distance <= state.ESPMaxDistance then
					createESPForPlayer(targetPlayer)
				elseif espObjects[targetPlayer] then
					removeESPForPlayer(targetPlayer)
				end
			end
		elseif espObjects[targetPlayer] then
			removeESPForPlayer(targetPlayer)
		end
	end

	for targetPlayer, data in pairs(espObjects) do
		updateESPObject(targetPlayer, data, now)
	end
end

