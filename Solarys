		end
	end

	-- Fly
	if state.Fly and humanoid and rootPart and camera then
		if not linearVelocity or not alignOrientation then
			startFly()
		end

		local cam = camera.CFrame
		local move = Vector3.zero

		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			move += cam.LookVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			move -= cam.LookVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			move -= cam.RightVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			move += cam.RightVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.E) then
			move += Vector3.new(0, 1, 0)
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.Q) then
			move -= Vector3.new(0, 1, 0)
		end

		local finalSpeed = state.FlySpeed

		if state.Boost and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			finalSpeed *= state.BoostMultiplier
		end

		local targetVelocity = Vector3.zero

		if move.Magnitude > 0.05 then
			targetVelocity = move.Unit * finalSpeed
		end

		currentVelocity = currentVelocity:Lerp(targetVelocity, math.clamp(dt * 8, 0, 1))
		linearVelocity.VectorVelocity = currentVelocity
		alignOrientation.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + cam.LookVector)
	end

	if not state.Fly and linearVelocity then
		stopFly()
	end

	-- Noclip optimisé : pas besoin de rescanner toutes les pièces à chaque frame
	if state.Noclip then
		noclipTimer += dt

		if noclipTimer >= 0.2 then
			noclipTimer = 0
			updateNoclip()
		end
	end

	-- Spin
	if state.Spin and rootPart then
		rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(state.SpinSpeed) * dt, 0)
	end

	-- Aim Assist optimisé
	if shouldAimAssist() and camera then
		aimScanTimer += dt

		if aimScanTimer >= AIM_SCAN_RATE then
			aimScanTimer = 0
			aimTargetPart = getClosestAimTarget()
		end

		if aimTargetPart and aimTargetPart.Parent then
			local camPos = camera.CFrame.Position
			local wanted = CFrame.lookAt(camPos, aimTargetPart.Position)
			local alpha = math.clamp(state.AimStrength / 100, 0.01, 0.7)

			camera.CFrame = camera.CFrame:Lerp(wanted, alpha)
		else
			aimTargetPart = nil
		end
	else
		currentTargetName = "Aucune"
		aimTargetPart = nil
		aimScanTimer = 0
	end

	local targetLine = "Cible actuelle : " .. currentTargetName
	if targetLine ~= lastTargetInfo then
		lastTargetInfo = targetLine
		targetInfo.Text = targetLine
	end

	updateESP(dt)
	updateTracker(dt)

end)

selectPage("Dashboard")
