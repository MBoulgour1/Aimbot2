		BackgroundColor3 = state[key] and Color3.fromRGB(55, 120, 255) or Color3.fromRGB(24, 24, 27),
		Text = state[key] and "ON" or "OFF",
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Font = Enum.Font.Code,
		TextSize = 13,
		AutoButtonColor = false,
		Parent = holder
	})

	corner(switch, 4)
	stroke(switch, Color3.fromRGB(65, 65, 70), 1, 0)

	local function setValue(value)
		state[key] = value
		switch.Text = value and "ON" or "OFF"

		tween(switch, {
			BackgroundColor3 = value and Color3.fromRGB(55, 120, 255) or Color3.fromRGB(24, 24, 27)
		})

		if callback then
			callback(value)
		end
	end

	switch.MouseButton1Click:Connect(function()
		setValue(not state[key])
	end)

	toggleSetters[key] = setValue
	return setValue
end

local function makeSlider(parent, key, titleText, minValue, maxValue, suffix, callback)
	local value = state[key]
	local dragging = false

	local holder = create("Frame", {
		Size = UDim2.new(1, 0, 0, 76),
		BackgroundColor3 = Color3.fromRGB(8, 8, 9),
		BorderSizePixel = 0,
		Parent = parent
	})

	corner(holder, 4)
	stroke(holder, Color3.fromRGB(42, 42, 46), 1, 0)

	create("TextLabel", {
		Size = UDim2.new(1, -110, 0, 24),
		Position = UDim2.new(0, 14, 0, 8),
		BackgroundTransparency = 1,
		Text = titleText,
		TextColor3 = Color3.fromRGB(245, 245, 245),
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = holder
	})

	local valueLabel = create("TextLabel", {
		Size = UDim2.new(0, 95, 0, 24),
		Position = UDim2.new(1, -110, 0, 8),
		BackgroundTransparency = 1,
		Text = tostring(value) .. (suffix or ""),
		TextColor3 = Color3.fromRGB(180, 180, 185),
		Font = Enum.Font.Code,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = holder
	})

	local track = create("Frame", {
		Size = UDim2.new(1, -28, 0, 6),
		Position = UDim2.new(0, 14, 0, 51),
		BackgroundColor3 = Color3.fromRGB(35, 35, 38),
		BorderSizePixel = 0,
		Parent = holder
	})

	corner(track, 99)

	local fill = create("Frame", {
		Size = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = Color3.fromRGB(55, 120, 255),
		BorderSizePixel = 0,
		Parent = track
	})

	corner(fill, 99)

	local knob = create("Frame", {
		Size = UDim2.new(0, 14, 0, 14),
		Position = UDim2.new(0, -7, 0.5, -7),
		BackgroundColor3 = Color3.fromRGB(245, 245, 245),
		BorderSizePixel = 0,
		Parent = track
	})

	corner(knob, 99)

	local function updateVisual()
		local alpha = math.clamp((value - minValue) / (maxValue - minValue), 0, 1)

		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, -7, 0.5, -7)

		if key == "BoostMultiplier" then
			valueLabel.Text = string.format("%.1f", value) .. (suffix or "")
		else
			valueLabel.Text = tostring(math.floor(value + 0.5)) .. (suffix or "")
		end
	end

	local function setValue(newValue)
		value = math.clamp(newValue, minValue, maxValue)
		state[key] = value
		updateVisual()

		if callback then
			callback(value)
		end
	end

	local function setFromX(x)
		local startX = track.AbsolutePosition.X
		local width = track.AbsoluteSize.X
		local alpha = math.clamp((x - startX) / width, 0, 1)

		setValue(minValue + ((maxValue - minValue) * alpha))
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setFromX(input.Position.X)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	updateVisual()
end

