local trackerTimer = 0

local function updateTracker(dt)
	trackerTimer += dt

	if trackerTimer < 0.4 then
		return
	end

	trackerTimer = 0

	if not state.TrackAll then
		trackerLabel.Text = "Track All désactivé."
		return
	end

	local lines = {}

	table.insert(lines, "TRACK ALL")
	table.insert(lines, "----------------------")

	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if targetPlayer ~= player then
			local distanceText = "N/A"
			local teamText = "No Team"

			if targetPlayer.Team then
				teamText = targetPlayer.Team.Name
			end

			if targetPlayer.Character and rootPart then
				local targetRoot = getSafeRoot(targetPlayer.Character)

				if targetRoot then
					local distance = (rootPart.Position - targetRoot.Position).Magnitude
					distanceText = tostring(math.floor(distance)) .. " studs"
				end
			end

			table.insert(lines, targetPlayer.Name .. " | " .. teamText .. " | " .. distanceText)
		end
	end

	if #lines <= 2 then
		table.insert(lines, "Aucun autre joueur.")
	end

	trackerLabel.Text = table.concat(lines, "\n")
end

--// MAIN LOOP

RunService.RenderStepped:Connect(function(dt)
	camera = workspace.CurrentCamera

	if camera then
		camera.FieldOfView = state.CameraFOV
	end

	-- Fly
	if state.Fly and humanoid and rootPart and camera then
		if not linearVelocity or not alignOrientation then
			startFly()
		end

		local cam = camera.CFrame
		local move = Vector3.zero

		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			move += cam.LookVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			move -= cam.LookVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			move -= cam.RightVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			move += cam.RightVector
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.E) then
			move += Vector3.new(0, 1, 0)
		end

		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.Q) then
			move -= Vector3.new(0, 1, 0)
		end

		local finalSpeed = state.FlySpeed

		if state.Boost and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			finalSpeed *= state.BoostMultiplier
		end

		local targetVelocity = Vector3.zero

		if move.Magnitude > 0.05 then
			targetVelocity = move.Unit * finalSpeed
		end

		currentVelocity = currentVelocity:Lerp(targetVelocity, math.clamp(dt * 8, 0, 1))
		linearVelocity.VectorVelocity = currentVelocity
		alignOrientation.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + cam.LookVector)
	end

	if not state.Fly and linearVelocity then
		stopFly()
	end

	-- Noclip
	updateNoclip()

	-- Spin
	if state.Spin and rootPart then
		rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, math.rad(state.SpinSpeed) * dt, 0)
	end

	-- Aim Assist propre
	if shouldAimAssist() and camera then
		local targetPart = getClosestAimTarget()

		if targetPart then
			local camPos = camera.CFrame.Position
			local wanted = CFrame.lookAt(camPos, targetPart.Position)
			local alpha = math.clamp(state.AimStrength / 100, 0.01, 0.7)

			camera.CFrame = camera.CFrame:Lerp(wanted, alpha)
		end
	else
		currentTargetName = "Aucune"
	end

	targetInfo.Text = "Cible actuelle : " .. currentTargetName

	updateESP(dt)
	updateTracker(dt)

	player:SetAttribute("NoRecoil", state.NoRecoil)
	player:SetAttribute("ClientFly", state.Fly)
	player:SetAttribute("AimAssist", state.AimAssist)
end)

